# Doxyfile 1.14.0
#
# Configuración de Doxygen para el proyecto Librerias-MCXA156.
# Genera documentación HTML de las librerías docentes del MCXA156.
#
# Uso:
#   doxygen Doxyfile

#---------------------------------------------------------------------------
# Opciones del proyecto
#---------------------------------------------------------------------------

DOXYFILE_ENCODING      = UTF-8
PROJECT_NAME           = "Librerías MCXA156"
PROJECT_NUMBER         = 1.0
PROJECT_BRIEF          = "Librerías docentes para el microcontrolador NXP MCXA156 (ARM Cortex-M33)"
PROJECT_LOGO           =
OUTPUT_DIRECTORY       = ./docs
OUTPUT_LANGUAGE        = Spanish

#---------------------------------------------------------------------------
# Opciones de compilación
#---------------------------------------------------------------------------

OPTIMIZE_OUTPUT_FOR_C  = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_METHODS  = YES

#---------------------------------------------------------------------------
# Entrada
#---------------------------------------------------------------------------

INPUT                  = ./Librerias
FILE_PATTERNS          = *.c \
                         *.h \
                         *.s \
                         *.S
RECURSIVE              = YES
EXCLUDE                =
EXCLUDE_PATTERNS       = */Objects/* \
                         */Listings/* \
                         */RTE/*

#---------------------------------------------------------------------------
# Navegador de código fuente
#---------------------------------------------------------------------------

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

#---------------------------------------------------------------------------
# Salida HTML
#---------------------------------------------------------------------------

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH         = 250

#---------------------------------------------------------------------------
# Otras salidas (deshabilitadas)
#---------------------------------------------------------------------------

GENERATE_LATEX         = NO
GENERATE_RTF           = NO
GENERATE_MAN           = NO
GENERATE_XML           = NO
GENERATE_DOCBOOK       = NO

#---------------------------------------------------------------------------
# Preprocesador
#---------------------------------------------------------------------------

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
PREDEFINED             = CPU_MCXA156VLL \
                         MCXA156_SERIES

#---------------------------------------------------------------------------
# Diagramas
#---------------------------------------------------------------------------

HAVE_DOT               = NO
GENERATE_LEGEND        = YES

#---------------------------------------------------------------------------
# Listas automáticas
#---------------------------------------------------------------------------

GENERATE_TODOLIST      = YES
GENERATE_TESTLIST      = YES
GENERATE_BUGLIST       = YES
GENERATE_DEPRECATEDLIST = YES
